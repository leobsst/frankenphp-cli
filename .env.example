APP_ENV=dev
UID=
GID=
MARIADB_ROOT_PASSWORD=

# Default project path (used if not specified in start command)
DEFAULT_PROJECT_PATH=

# Default PHP version for new domains (8.2, 8.3, 8.4, 8.5)
# Used when --php is not specified in start/add-host commands
DEFAULT_PHP_VERSION=8.3

# Storage paths (relative to data directory, or absolute paths)
# Leave empty for defaults: ./caddy, ./database
CADDY_DIR=
DATABASE_DIR=

# Set to "true" to expose services to the network.
# By default, services are bound to localhost only (127.0.0.1).
EXPOSE_SERVICES=false

# Service ports (host:container format when EXPOSE_SERVICES=false uses 127.0.0.1 prefix)
DB_PORT=3306
PMA_PORT=8080
REDIS_PORT=6379

# Web server ports (FrankenPHP/Caddy)
WEB_HTTP_PORT=80
WEB_HTTPS_PORT=443

# Maximum packet size for MariaDB (e.g., 16M, 128M, 512M)
MYSQL_MAX_ALLOWED_PACKET=512M
