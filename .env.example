APP_ENV=dev
USER=
GROUP=
CERTS_DIR="./caddy/certs"
MARIADB_ROOT_PASSWORD=

# Set to "true" to expose phpMyAdmin and Redis to the network.
# By default, services are bound to localhost only (127.0.0.1).
EXPOSE_SERVICES=false

# Maximum packet size for MariaDB (e.g., 16M, 128M, 512M)
MYSQL_MAX_ALLOWED_PACKET=512M
